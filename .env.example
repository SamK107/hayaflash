# =============================================================================
# HayaFlash — environment template
# Copy to ".env" (never commit ".env"). See project README / docs for prod.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
# dev | prod (informational; choose settings via DJANGO_SETTINGS_MODULE)
ENV=dev
DJANGO_SETTINGS_MODULE=config.settings.dev

# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------
# Production: required, strong random string. Dev: set for stable sessions.
SECRET_KEY=
# Dev only: parsed by config.settings.dev (ignored in prod settings module)
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Database — SQLite (local dev, config.settings.dev)
# -----------------------------------------------------------------------------
# Filename under project root; default avoids legacy db.sqlite3 history issues
DEV_SQLITE_NAME=local.sqlite3

# -----------------------------------------------------------------------------
# Database — PostgreSQL (production, config.settings.prod)
# -----------------------------------------------------------------------------
# Preferred names:
DB_NAME=hayaflash
DB_USER=hayaflash
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Legacy aliases (optional): used only if DB_* above are empty
# POSTGRES_DB=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=
# POSTGRES_PORT=

# -----------------------------------------------------------------------------
# Static & media (optional overrides; safe defaults exist in settings)
# -----------------------------------------------------------------------------
# STATIC_URL=static/
# STATIC_ROOT=
# MEDIA_URL=media/
# MEDIA_ROOT=

# -----------------------------------------------------------------------------
# Security (production-oriented; dev may leave CORS empty)
# -----------------------------------------------------------------------------
SECURE_SSL_REDIRECT=true
CSRF_TRUSTED_ORIGINS=https://app.example.com
CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=noreply@example.com
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true

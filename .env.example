# =============================================================================
# HayaFlash — environment template
# Copy to ".env" (never commit ".env"). See project README / docs for prod.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
# Logical label: dev | staging | prod (legacy alias: ENV)
ENVIRONMENT=dev
# Optional legacy key (used only if ENVIRONMENT is unset):
# ENV=dev

# Django settings module (loaded early in manage.py / WSGI / ASGI via dotenv):
#   config.settings.dev     — SQLite db_dev.sqlite3, DEBUG on
#   config.settings.staging — PostgreSQL, DEBUG off
#   config.settings.prod    — PostgreSQL, DEBUG off, strict security
DJANGO_SETTINGS_MODULE=config.settings.dev

# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------
# Production / staging: required, strong random string.
# Dev: optional; ephemeral key is generated if empty (see dev settings warning).
SECRET_KEY=
# Parsed in base first; dev module forces DEBUG=True. Never use DEBUG=true with
# ENVIRONMENT=prod (base will refuse to start).
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Cache / Redis (optional in dev; recommended staging/prod for OTP + multi-worker)
# -----------------------------------------------------------------------------
# If set, default cache uses Redis (django-redis). If unset, LocMemCache is used.
# REDIS_URL=redis://127.0.0.1:6379/1

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# If set (non-empty), DATABASE_URL wins over DB_* (dj-database-url).
# Staging/prod must resolve to PostgreSQL (postgres:// or postgresql://).
# Leave unset or empty to use SQLite (dev) or DB_* (staging/prod).
# Example: postgres://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=

# SQLite file name under project root when ENVIRONMENT=dev and DATABASE_URL is unset.
# DEV_SQLITE_NAME=db_dev.sqlite3

# PostgreSQL via discrete variables (required for staging/prod when DATABASE_URL is unset).
DB_NAME=hayaflash
DB_USER=hayaflash
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# -----------------------------------------------------------------------------
# Static & media (optional overrides; safe defaults exist in settings)
# -----------------------------------------------------------------------------
# STATIC_URL=static/
# STATIC_ROOT=
# MEDIA_URL=media/
# MEDIA_ROOT=

# Public base URL for share links / WhatsApp (optional; dev uses request host).
# HAYAFLASH_PUBLIC_BASE_URL=https://app.example.com

# -----------------------------------------------------------------------------
# Security (production / staging; dev may leave CORS empty)
# -----------------------------------------------------------------------------
SECURE_SSL_REDIRECT=true
CSRF_TRUSTED_ORIGINS=https://app.example.com
CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Payments / Mobile Money webhooks (staging/prod: set strong secrets)
# -----------------------------------------------------------------------------
# HMAC SHA256 over raw webhook JSON body; header: X-Payment-Signature: sha256=<hex>
# PAYMENTS_WEBHOOK_SECRET=
# Force mock provider to fail immediately (testing).
# PAYMENTS_MOCK_SIMULATE_FAILURE=false

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=noreply@example.com
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true

# -----------------------------------------------------------------------------
# SMS — Orange Mali API (notifications commandes)
# -----------------------------------------------------------------------------
# ORANGE_SMS_API_KEY=
# ORANGE_SMS_BASE_URL=https://api.orange.com/smsmessaging/v1

# -----------------------------------------------------------------------------
# Sentry (production uniquement — monitoring erreurs)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# -----------------------------------------------------------------------------
# Docker / CI — Image et domaine de production
# -----------------------------------------------------------------------------
# Tag Docker de l'image à déployer (utilisé par docker-compose.production.yml)
# DOCKER_IMAGE=hayaflash
# IMAGE_TAG=latest

# Domaine public (utilisé par Nginx prod.conf et smoke_test.sh)
# PROD_DOMAIN=app.hayaflash.com

# Mot de passe Redis en production (optionnel, recommandé)
# REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Celery (override optionnel — par défaut REDIS_URL)
# -----------------------------------------------------------------------------
# CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Orange Money Paiement abonnements ─────────────────────────────────────────
# Obtenir sur https://developer.orange.com/ (espace Mali)
# ORANGE_ML_CLIENT_ID=
# ORANGE_ML_CLIENT_SECRET=
# ORANGE_ML_MERCHANT_KEY=
# URL publique pour les callbacks (HTTPS obligatoire, pas de localhost)
# Dev  : utilisez ngrok  →  ORANGE_MONEY_BASE_URL=https://xxxx.ngrok-free.app
# Prod : ORANGE_MONEY_BASE_URL=https://votredomaine.com
# ORANGE_ML_BASE_URL=
